{
  "name": "docker-browser",
  "version": "0.1.0",
  "main": "dist-electron/main/index.js",
  "description": "Docker Browser — Electron desktop client for local Docker Engine management.",
  "author": "Guo's",
  "license": "MIT",
  "private": true,
  "type": "module",
  "pnpm": {
    "//overrides.builder-util-runtime": "锁定 builder-util-runtime，避免 electron-builder / electron-updater 传递依赖版本漂移导致构建或运行时异常。升级 electron-builder 后可删除 override 并执行 pnpm i && pnpm dist 验证。",
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ],
    "overrides": {
      "builder-util-runtime": "9.5.1"
    }
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7788/"
    }
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "rebuild": "pnpm clean && pnpm dist",
    "dev": "vite",
    "build": "tsc && vite build",
    "rebuild:electron": "node scripts/ensure-win-msvc.mjs && electron-rebuild -f -w node-pty",
    "dist": "pnpm run build && node scripts/gen-icon-ico.mjs && pnpm run rebuild:electron && electron-builder --publish never",
    "dist:dir": "pnpm run build && node scripts/gen-icon-ico.mjs && pnpm run rebuild:electron && electron-builder --dir --publish never",
    "typecheck": "tsc --noEmit",
    "pretest": "vite build --mode=test",
    "test": "vitest run",
    "test:watch": "vitest",
    "icon:render": "node scripts/render-icon.mjs"
  },
  "dependencies": {
    "@balena/dockerignore": "^1.0.2",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "builder-util-runtime": "9.5.1",
    "docker-modem": "^5.0.7",
    "dockerode": "^4.0.2",
    "electron-updater": "^6.3.9",
    "fs-extra": "^11.3.4",
    "graceful-fs": "^4.2.11",
    "i18next": "^26.0.3",
    "jsonfile": "^6.2.1",
    "node-pty": "^1.1.0",
    "protobufjs": "^8.0.1",
    "react-i18next": "^17.0.2",
    "tar-fs": "^3.1.2",
    "tar-stream": "^3.1.8",
    "universalify": "^2.0.1",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/dockerode": "^4.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/tar-stream": "^3.1.4",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.0",
    "rcedit": "^5.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.4.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.0.5"
  }
}
